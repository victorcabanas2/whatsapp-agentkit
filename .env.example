# AgentKit — Template de Variables de Entorno
# Copia este archivo a .env y completa tus valores reales
# NUNCA commites .env a GitHub

# ════════════════════════════════════════════════════════════
# REQUIRED: Anthropic API
# Obtener en: https://console.anthropic.com/account/keys
# ════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...

# ════════════════════════════════════════════════════════════
# REQUIRED: Proveedor de WhatsApp
# Opciones: whapi, meta, twilio
# ════════════════════════════════════════════════════════════
WHATSAPP_PROVIDER=whapi

# ════════════════════════════════════════════════════════════
# WHAPI.CLOUD (si WHATSAPP_PROVIDER=whapi)
# Obtener token en: https://whapi.cloud
# ════════════════════════════════════════════════════════════
WHAPI_TOKEN=...

# ════════════════════════════════════════════════════════════
# META CLOUD API (si WHATSAPP_PROVIDER=meta)
# Obtener en: https://developers.facebook.com
# ════════════════════════════════════════════════════════════
# META_ACCESS_TOKEN=...
# META_PHONE_NUMBER_ID=...
# META_VERIFY_TOKEN=agentkit-verify

# ════════════════════════════════════════════════════════════
# TWILIO (si WHATSAPP_PROVIDER=twilio)
# Obtener en: https://twilio.com
# ════════════════════════════════════════════════════════════
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=...

# ════════════════════════════════════════════════════════════
# SERVIDOR
# ════════════════════════════════════════════════════════════
PORT=8000
ENVIRONMENT=development
# ENVIRONMENT=production  # Cambiar para Railway

# ════════════════════════════════════════════════════════════
# BASE DE DATOS
# Local (desarrollo):   sqlite+aiosqlite:///./agentkit.db
# PostgreSQL (Railway): postgresql+asyncpg://user:pass@host:5432/db
# ════════════════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db

# ════════════════════════════════════════════════════════════
# ADMIN / ALERTAS
# ════════════════════════════════════════════════════════════
VENDEDOR_WHATSAPP=595986147509
ADMIN_PASSWORD=rebody2024
ADMIN_WHATSAPP=+595986147509

# ════════════════════════════════════════════════════════════
# SHOPIFY (OPCIONAL)
# ════════════════════════════════════════════════════════════
# SHOPIFY_API_KEY=...
# SHOPIFY_API_PASSWORD=...
# SHOPIFY_SHOP_NAME=...
